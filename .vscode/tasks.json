{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo build",
      "type": "cargo",
      "command": "build",
      "args": ["--no-default-features", "--features", "gui"],
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "cargo build (release)",
      "type": "cargo",
      "command": "build",
      "args": ["--release", "--no-default-features", "--features", "gui"],
      "problemMatcher": ["$rustc"],
      "group": "build"
    },
    {
      "label": "cargo test",
      "type": "cargo",
      "command": "test",
      "args": ["--no-default-features", "--features", "gui"],
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "cargo clippy",
      "type": "cargo",
      "command": "clippy",
      "args": ["--no-default-features", "--features", "gui"],
      "problemMatcher": ["$rustc"],
      "group": "build"
    }
  ]
}
